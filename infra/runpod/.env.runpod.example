# Copy to infra/runpod/.env.runpod and fill locally. Do not commit .env.runpod.
RUNPOD_HOST=
RUNPOD_SSH_PORT=22
RUNPOD_USER=root
RUNPOD_SSH_KEY=
RUNPOD_REMOTE_DIR=/workspace/aetherville

# Optional public URLs/ports after RunPod exposes them
RUNPOD_PUBLIC_ORCHESTRATOR_URL=http://YOUR_RUNPOD_HOST:8080
RUNPOD_PUBLIC_VISION_URL=http://YOUR_RUNPOD_HOST:8001
RUNPOD_PUBLIC_VLLM_URL=http://YOUR_RUNPOD_HOST:8000/v1

# Optional model/runtime secrets
HF_TOKEN=
MODEL_NAME=Qwen/Qwen2.5-14B-Instruct-AWQ
AETHERVILLE_JWT_SECRET=change-me
VLLM_GPU_MEMORY_UTILIZATION=0.90
