# Copy to infra/runpod/.env.runpod and fill locally. Do not commit .env.runpod.
RUNPOD_HOST=
RUNPOD_SSH_PORT=22
RUNPOD_USER=root
RUNPOD_SSH_KEY=
RUNPOD_REMOTE_DIR=/workspace/aetherville

# Optional public URLs/ports after RunPod exposes them
RUNPOD_PUBLIC_ORCHESTRATOR_URL=http://YOUR_RUNPOD_HOST:8080
RUNPOD_PUBLIC_SOCKET_URL=http://YOUR_RUNPOD_HOST:8080
RUNPOD_PUBLIC_VISION_URL=http://YOUR_RUNPOD_HOST:18001
RUNPOD_PUBLIC_VLLM_URL=http://YOUR_RUNPOD_HOST:8000/v1

# Optional model/runtime secrets
HF_TOKEN=
MODEL_NAME=Qwen/Qwen2.5-14B-Instruct-AWQ
AETHERVILLE_JWT_SECRET=change-me
VLLM_GPU_MEMORY_UTILIZATION=0.90

# God Mode command interpretation: rules by default, set to vllm only for approved real-vLLM demos.
AETHERVILLE_GOD_MODE_LLM=rules

# Autonomous city director: disabled by default. Set to vllm only when the
# orchestrator should ask the RunPod vLLM endpoint for bounded city plans.
AETHERVILLE_CITY_AI_MODE=disabled
AETHERVILLE_CITY_AI_INTERVAL_TICKS=120
AETHERVILLE_CITY_AI_LLM_TIMEOUT_SEC=7

# Optional God Mode voice/STT. Use faster_whisper only after model/runtime approval.
AETHERVILLE_STT_MODE=stub
AETHERVILLE_STT_MODEL=base
AETHERVILLE_STT_DEVICE=cuda
AETHERVILLE_STT_COMPUTE_TYPE=int8_float16

# 5090 migration/deploy helpers
# safe-smoke profile uses mock services and no model downloads.
AETHERVILLE_APPROVE_REAL_AI=0
AETHERVILLE_BOOTSTRAP_UV=1
AETHERVILLE_VLLM_MODE=mock
AETHERVILLE_LLM_MODE=cache
AETHERVILLE_VISION_MODE=mock
AETHERVILLE_REDIS_MODE=memory
AETHERVILLE_VISION_PORT=18001
AETHERVILLE_ORCHESTRATOR_PORT=8080
AETHERVILLE_VLLM_PORT=8000
AETHERVILLE_MODEL_CACHE_DIR=/workspace/aetherville-model-cache
# For real-demo only, set AETHERVILLE_APPROVE_REAL_AI=1 in the shell and let
# infra/runpod/deploy_5090_direct.sh export guarded real vLLM/YOLO defaults.
AETHERVILLE_VLLM_INSTALL_PACKAGE=vllm==0.10.2
AETHERVILLE_VLLM_COMPAT_PACKAGE=transformers==4.55.4
VLLM_MAX_MODEL_LEN=8192

# Guarded model-weight training pipeline. Keep approval disabled unless a paid GPU
# training window is intentionally started. Dry-run cycles still build datasets and
# evaluation evidence without mutating weights.
AETHERVILLE_TRAINING_DIR=/workspace/aetherville-training
AETHERVILLE_APPROVE_MODEL_TRAINING=0
