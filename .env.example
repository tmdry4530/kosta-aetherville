# Local browser/client endpoints. Override with RunPod public REST/WSS URLs for cloud demos.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8080
NEXT_PUBLIC_SOCKET_URL=http://localhost:8080

# Direct-process service defaults for local/RunPod smoke tests.
AETHERVILLE_ORCHESTRATOR_HOST=0.0.0.0
AETHERVILLE_ORCHESTRATOR_PORT=8080
AETHERVILLE_VISION_URL=http://127.0.0.1:8001
AETHERVILLE_VLLM_URL=http://127.0.0.1:8000/v1
AETHERVILLE_REDIS_URL=redis://127.0.0.1:6379/0

# Service ports for direct-process and Compose paths.
AETHERVILLE_SERVICE_HOST=0.0.0.0
AETHERVILLE_VISION_PORT=8001
AETHERVILLE_VLLM_PORT=8000
AETHERVILLE_REDIS_PORT=6379
AETHERVILLE_VLLM_MODE=mock
AETHERVILLE_REDIS_MODE=memory
